<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.korboy.ipadecryptd</string>
    <key>ProgramArguments</key>
    <array>
        <string>/var/jb/bin/sh</string>
        <string>/var/jb/usr/libexec/ipadecryptd-supervisor</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>UserName</key>
    <string>root</string>
    <key>AbandonProcessGroup</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/var/jb/tmp/ipadecryptd-supervisor.log</string>
    <key>StandardErrorPath</key>
    <string>/var/jb/tmp/ipadecryptd-supervisor.err</string>
</dict>
</plist>
